# Toxic Sentinel Service Configuration
# Copy this file to .env and fill in your values

# Server
PORT=8086
LOG_LEVEL=INFO

# Authentication (required - generate a strong random key)
API_KEY=your_secret_api_key_here

# Device configuration
# DEVICE=cuda   # optional: override auto-detection (cuda|cpu). Default: auto (cuda if available else cpu)
DEVICE=cpu

# Hugging Face cache directory (mount as volume in Docker)
HF_HOME=/app/.cache

# Model
MODEL_NAME=pythainlp/wangchanberta-base-att-spm-uncased

# Detection tuning
TOXIC_THRESHOLD=0.5
MAX_TEXT_LENGTH=1000

# Inference concurrency (protect GPU memory)
MAX_CONCURRENT_INFERENCES=1

# CORS (comma-separated origins, or * for all)
CORS_ORIGINS=

# OpenAPI docs (true|false)
ENABLE_DOCS=true