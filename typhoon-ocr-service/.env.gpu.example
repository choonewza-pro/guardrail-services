# Server Configuration (GPU Instance)
PORT=8087
LOG_LEVEL=INFO
ENABLE_DOCS=true

# Authentication
API_KEY=dev_ocr_secret_key_123

# Hardware & Model Settings
DEVICE=cuda
MODEL_NAME=typhoon-ai/typhoon-ocr1.5-2b
MODEL_DTYPE=auto

# HuggingFace Cache Directory
HF_HOME=/app/.cache

# Default OCR Settings
DEFAULT_MAX_TOKENS=4096
DEFAULT_TEMPERATURE=0.1
DEFAULT_TIMEOUT=500.0
DEFAULT_MAX_RETRIES=3
MAX_IMAGE_SIZE=1800

# CORS
CORS_ORIGINS=
