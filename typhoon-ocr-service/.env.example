# Server Configuration
PORT=8087
LOG_LEVEL=INFO
ENABLE_DOCS=true

# Authentication
API_KEY=your_secret_key_here

# Hardware & Model Settings
# DEVICE: auto | cuda | cpu
DEVICE=auto

# MODEL_NAME: HuggingFace model ID (default: typhoon-ai/typhoon-ocr1.5-2b or scb10x/typhoon-ocr1.5-3b)
MODEL_NAME=typhoon-ai/typhoon-ocr1.5-2b

# MODEL_DTYPE: auto | float16 | bfloat16 | float32
MODEL_DTYPE=auto

# HuggingFace Cache Directory
HF_HOME=/app/.cache

# Default OCR Settings
DEFAULT_MAX_TOKENS=4096
DEFAULT_TEMPERATURE=0.1
DEFAULT_TIMEOUT=60.0
DEFAULT_MAX_RETRIES=3
MAX_IMAGE_SIZE=1800

# CORS (Comma-separated origins, e.g. http://localhost:3000,http://localhost:8080)
CORS_ORIGINS=
