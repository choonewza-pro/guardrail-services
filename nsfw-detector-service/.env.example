# NSFW Detector Service Configuration
# Copy this file to .env and fill in your values

# Server
PORT=8085
LOG_LEVEL=INFO

# Authentication (required - generate a strong random key)
API_KEY=your_secret_api_key_here

# Device configuration (auto|cuda|cpu, default=auto -> cuda if available else cpu)
DEVICE=auto
# DEVICE=cuda
# DEVICE=cpu

# Hugging Face cache directory (mount as volume in Docker)
HF_HOME=/app/.cache

# Model
MODEL_NAME=Marqo/nsfw-image-detection-384

# Upload limits
MAX_IMAGE_SIZE_MB=10
ALLOWED_MIME=image/jpeg,image/png,image/webp

# Detection tuning
NSFW_THRESHOLD=0.6
MAX_DIMENSION=1024

# Inference concurrency (protect GPU memory)
MAX_CONCURRENT_INFERENCES=1

# CORS (comma-separated origins, or * for all)
CORS_ORIGINS=

# OpenAPI docs (true|false)
ENABLE_DOCS=true